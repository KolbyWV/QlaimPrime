{
  "name": "prime",
  "version": "1.0.0",
  "description": "Qlaim Prime",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node --import tsx/esm src/index.ts",
    "dev": "tsx watch src/index.ts",
    "seed": "node --import tsx/esm prisma/seed.ts",
    "db:seed": "prisma db seed",
    "test": "npm run test:seed:integrity",
    "test:seed:integrity": "node --import tsx/esm scripts/test-seed-integrity.js",
    "test:smoke:api": "node scripts/test-api-smoke.js",
    "backfill:gig-base-stars:dry": "node scripts/backfill-gig-base-stars.js",
    "backfill:gig-base-stars": "node scripts/backfill-gig-base-stars.js --apply",
    "backfill:assignment-stars:dry": "node scripts/backfill-assignment-stars.js",
    "backfill:assignment-stars": "node scripts/backfill-assignment-stars.js --apply"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "argon2": "^0.44.0",
    "cors": "^2.8.6",
    "dataloader": "^2.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "graphql": "^16.12.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.5",
    "dotenv": "^17.3.1",
    "prisma": "^7.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.12"
  },
  "prisma": {
    "seed": "node --import tsx/esm prisma/seed.ts"
  }
}
